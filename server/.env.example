DATABASE_URL=postgresql://user:password@localhost:5432/churchdb
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000
DB_QUERY_TIMEOUT_MS=30000
PORT=5001
NODE_ENV=development
SESSION_SECRET=replace-with-strong-random-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=true
SESSION_COOKIE_SAME_SITE=lax

# Optional bootstrap admin (for seed scripts only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# SMS Provider Configuration
SMS_PROVIDER=FROG

# FROG (Wigal) SMS Configuration
FROG_API_KEY=your-frog-api-key
FROG_USERNAME=your-frog-username
FROG_SENDER_ID=ECCLESIA

# Arkesel SMS Configuration
ARKESEL_SMS_API_KEY=your-arkesel-api-key
ARKESEL_SENDER_ID=ECCLESIA

# Automation feature flags
ENABLE_AUTOMATED_SMS=true
ENABLE_BIRTHDAY_SMS=true
ENABLE_ANNIVERSARY_SMS=true
ENABLE_ABSENTEE_SMS=true
