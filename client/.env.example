GEMINI_API_KEY=PLACEHOLDER_API_KEY

# Local dev: keep frontend fetches relative and let Vite proxy /api and /uploads.
VITE_API_PROXY_TARGET=http://localhost:5001

# Optional production/split-host setup: set this only when the browser should call
# the API origin directly instead of using same-origin /api paths.
VITE_API_BASE_URL=
